       <property name="styleSheet">
        <string notr="true">/* Butonul de Trimite Sesizarea (Albastru) */
QPushButton#btnTrimiteSesizareaGuest {
    background-color: #3498db;
    color: white;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    border: none;
}

QPushButton#btnTrimiteSesizareaGuest:hover {
    background-color: #2980b9;
}

QPushButton#btnTrimiteSesizareaGuest:pressed {
    background-color: #1c598a;
}

/* Butonul de LogOut / Back (Roșu) */
QPushButton#btnLogoutGuest, QPushButton#btnLogoutAdmin, QPushButton#btnLogoutAngajat {
    background-color: #e74c3c;
    color: white;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    border: none;
}

QPushButton#btnLogoutGuest:hover, QPushButton#btnLogoutAdmin:hover, QPushButton#btnLogoutAngajat:hover {
    background-color: #c0392b;
}

QPushButton#btnLogoutGuest:pressed, QPushButton#btnLogoutAdmin:pressed, QPushButton#btnLogoutAngajat:pressed {
    background-color: #a93226;
}</string>
