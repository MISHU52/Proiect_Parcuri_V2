      <widget class="QWidget" name="pageCreareAngajat">
       <property name="styleSheet">
        <string notr="true">/* Stil pentru fundalul paginii */
QWidget#pageCreareAngajat {
    background-color: #f5f7fa;
}

/* Stil pentru titlu */
QLabel {
    font-size: 24px;
    font-weight: bold;
    color: #2d3436;
    margin-bottom: 20px;
}

/* Stil pentru câmpurile de text (Input) */
QLineEdit {
    padding: 10px;
    border: 2px solid #dfe6e9;
    border-radius: 8px;
    background-color: white;
    font-size: 14px;
    min-width: 250px;
}

QLineEdit:focus {
    border: 2px solid #0984e3; /* Albastru când dai click în el */
}

/* Stil pentru butonul principal &quot;Creează Cont&quot; */
QPushButton#btnSalveazaAngajat {
    background-color: #00b894; /* Verde modern */
    color: white;
    border-radius: 8px;
    padding: 12px;
    font-weight: bold;
    font-size: 15px;
    min-width: 150px;
}

QPushButton#btnSalveazaAngajat:hover {
    background-color: #55efc4; /* Verde mai deschis la hover */
}

QPushButton#btnSalveazaAngajat:pressed {
    background-color: #00a884;
}

/* Stil pentru butonul de Anulează */
QPushButton#btnBackDinCreare {
    background-color: red;
    color: white;
    border: 2px solid #b2bec3;
    border-radius: 8px;
    padding: 8px;
    font-size: 13px;
}

QPushButton#btnBackDinCreare:hover {
    background-color: #dfe6e9;
    color: #2d3436;
}</string>
       </property>
