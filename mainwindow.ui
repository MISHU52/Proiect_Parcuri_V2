      <widget class="QWidget" name="pageRapoarte">
       <property name="styleSheet">
        <string notr="true">
QWidget#pageRapoarte {
    background-color: #f5f7fa;
}
QListWidget#listAngajatiRapoarte {
    border: 1px solid #dfe6e9;
    border-radius: 8px;
    background: white;
    font-size: 13px;
}
QListWidget#listAngajatiRapoarte::item:selected {
    background-color: #8e44ad;
    color: white;
    border-radius: 4px;
}
QTableWidget#tableRapoarte {
    border: 1px solid #dfe6e9;
