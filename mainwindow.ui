      <widget class="QWidget" name="page_4">
       <property name="styleSheet">
        <string notr="true">/* --- STIL TABEL ADMIN --- */
QTableWidget#tableTaskuriAdmin {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 10px;
    gridline-color: #f5f6fa;
    selection-background-color: #3498db;
    selection-color: white;
    outline: none;
}

/* Stil pentru antetul tabelului (Capul de tabel) */
QHeaderView::section {
    background-color: #2c3e50; /* Bleumarin închis */
    color: white;
    padding: 10px;
    border: none;
    font-weight: bold;
    font-size: 13px;
}

/* --- STIL ZONA DE INPUT (Ce trebuie facut / Angajat) --- */
QLineEdit#inputTaskAdmin, QComboBox#comboAngajatAdmin {
    border: 2px solid #bdc3c7;
    border-radius: 8px;
    padding: 8px 12px;
    background-color: white;
    color: #2c3e50;
    min-height: 25px;
}

QLineEdit#inputTaskAdmin:focus {
    border: 2px solid #3498db; /* Albastru la click */
}

/* --- BUTONUL DE ADĂUGARE TASK (Verde) --- */
QPushButton#btnAdaugaTaskManual {
    background-color: #27ae60;
    color: white;
    border-radius: 8px;
    font-weight: bold;
    min-height: 45px;
}

QPushButton#btnAdaugaTaskManual:hover {
    background-color: #219150;
}

/* --- BUTONUL GO BACK (Gri discret) --- */
QPushButton#btnBackToDash {
    background-color: transparent;
    border: 2px solid #95a5a6;
    color: #7f8c8d;
    border-radius: 8px;
    font-weight: bold;
    min-height: 35px;
}

QPushButton#btnBackToDash:hover {
    background-color: #95a5a6;
    color: white;
}

/* --- TITLUL PAGINII --- */
QLabel#label_9 {
    color: #2c3e50;
    font-size: 22px;
    font-weight: bold;
    margin-bottom: 10px;
}</string>
       </property>
