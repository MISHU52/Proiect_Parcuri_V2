       <property name="styleSheet">
        <string notr="true">/* Stil pentru containerul formularului */
QFrame#frameFormular {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 12px;
}

/* Stil pentru input-uri */
QLineEdit#inputNumeEveniment, QDateEdit#dateEveniment, QComboBox#comboLocatie {
    border: 2px solid #ecf0f1;
    border-radius: 6px;
    padding: 8px;
    min-height: 30px;
}

/* Butonul de Programare */
QPushButton#btnAprobaEveniment {
    background-color: #3498db;
    color: white;
    border-radius: 8px;
    font-weight: bold;
    font-size: 15px;
    min-height: 50px;
}

QPushButton#btnAprobaEveniment:hover {
    background-color: #2980b9;
}

/* Tabelul */
QTableWidget#tableEvenimenteAdmin {
    background-color: white;
    border-radius: 10px;
    gridline-color: #f1f2f6;
}</string>
       </property>
