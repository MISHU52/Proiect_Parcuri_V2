      <widget class="QWidget" name="page_6">
       <property name="styleSheet">
        <string notr="true">/* Stil pentru tabelul de sesizări */
QTableWidget#tableSesizariAdmin {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    gridline-color: #f5f6fa;
}

/* Butonul Ignoră - Roșu pentru a indica ștergerea */
QPushButton#btnIgnoraSesizarea {
    background-color: transparent;
    border: 2px solid #e74c3c;
    color: #e74c3c;
    border-radius: 8px;
    font-weight: bold;
    min-height: 40px;
}

QPushButton#btnIgnoraSesizarea:hover {
    background-color: #e74c3c;
    color: white;
}

/* Butonul de Conversie - Albastru închis/Professional */
QPushButton#btnConvertTask {
    background-color: #2c3e50;
    color: white;
    border-radius: 8px;
    font-weight: bold;
    min-height: 40px;
}

QPushButton#btnConvertTask:hover {
    background-color: #34495e;
}</string>
