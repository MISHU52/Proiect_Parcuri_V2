      <widget class="QWidget" name="page_1">
       <property name="styleSheet">
        <string notr="true">/* Stil general pentru butoanele din meniu */
QPushButton {
    background-color: #ffffff;
    border: 2px solid #2c3e50; /* O culoare elegantă de bleumarin închis */
    border-radius: 12px;
    color: #2c3e50;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
    font-weight: bold;
    padding: 10px;
    min-height: 60px; /* Le facem mai înalte să pară butoane de dashboard */
}

/* Efect când treci cu mouse-ul peste butoane */
QPushButton:hover {
    background-color: #34495e;
    color: white;
    border: 2px solid #34495e;
}

/* Stil pentru butonul de LogOut (să iasă în evidență) */
QPushButton#btnLogoutAdmin {
    background-color: #e74c3c; /* Roșu */
    border: none;
    color: white;
    min-height: 45px;
    border-radius: 8px;
}

QPushButton#btnLogoutAdmin:hover {
    background-color: #c0392b; /* Roșu mai închis la hover */
}

/* Butonul de Gestiune Inventar (care e singur pe rând) */
QPushButton#btnGoInventar {
    border: 2px solid #27ae60; /* Verde */
    color: #27ae60;
}

QPushButton#btnGoInventar:hover {
    background-color: #27ae60;
    color: white;
}

QPushButton#btnGoRapoarte {
    border: 2px solid #8e44ad;
    color: #8e44ad;
}

QPushButton#btnGoRapoarte:hover {
    background-color: #8e44ad;
    color: white;
}</string>
