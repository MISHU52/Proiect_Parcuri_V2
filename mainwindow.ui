       <property name="styleSheet">
        <string notr="true">/* Stil tabel Istoric */
QTableWidget#tableIstoric {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 10px;
    gridline-color: #f1f2f6;
    alternate-background-color: #f8f9fa; /* Rânduri gri deschis alternante */
}

/* Antetul tabelului */
QHeaderView::section {
    background-color: #2c3e50; /* Bleumarin închis */
    color: white;
    padding: 8px;
    font-weight: bold;
    border: none;
}

/* Stil pentru celulele selectate */
QTableWidget::item:selected {
    background-color: #3498db;
    color: white;
}</string>
