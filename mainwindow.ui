        <string notr="true">/* Stil pentru containerul formularului */
QFrame#frameFormular {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 12px;
}

/* Stil pentru input-uri */
QLineEdit#inputNumeEveniment, QDateEdit#dateEveniment, QComboBox#comboLocatie {
    border: 2px solid #ecf0f1;
    border-radius: 6px;
    padding: 8px;
    min-height: 30px;
}

/* Butonul de Programare */
