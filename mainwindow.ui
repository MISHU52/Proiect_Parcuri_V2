  <property name="styleSheet">
   <string notr="true">/* Fundalul principal */
#centralwidget {
    background-color: #cfd8dc;
}

/* Titlul principal */
QLabel {
    color: #2c3e50;
    font-family: &quot;Segoe UI&quot;, sans-serif;
}

/* Câmpurile de text (User și Parolă) */
QLineEdit {
    background-color: white;
    border: 1px solid #b0bec5;
    border-radius: 5px;
    padding: 8px;
    color: #37474f;
}

QLineEdit:focus {
    border: 2px solid #3498db;
}

/* Butonul de Login (Verde) */
QPushButton#btnLogin {
    background-color: #2ecc71;
    color: white;
    border-radius: 5px;
    padding: 10px;
    font-weight: bold;
    font-size: 14px;
}

QPushButton#btnLogin:hover {
    background-color: #27ae60;
}

/* Butonul de Guest (Albastru) */
QPushButton#btnJoinGuest {
    background-color: #3498db;
    color: white;
    border-radius: 5px;
    padding: 10px;
    font-size: 14px;
}

QPushButton#btnJoinGuest:hover {
    background-color: #2980b9;
}

/* Butoanele de Logout (Roșu/Portocaliu) */
QPushButton#btnLogoutAdmin, QPushButton#btnLogoutAngajat, QPushButton#btnBackGuest {
    background-color: #e74c3c;
    color: white;
    border-radius: 5px;
    padding: 8px;
}</string>
  </property>
